# Copy to insurance_pipeline/.env and fill in real values. Never commit .env.

# LLM keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Apollo for DM enrichment. Required for FL SunBiz leads — without
# it the registered-agent service company (CT Corp, Northwest) ends
# up as the DM panel, which is useless.
APOLLO_API_KEY=

# Upload endpoint — for `daily_run --upload`. Points at the
# Vercel deployment of api/upload-insurance-leads.js. Different
# blob key than the MSP pipeline so the two never collide. Reuses
# the MSP pipeline's LEADS_UPLOAD_API_KEY Bearer secret for v1.
INSURANCE_UPLOAD_URL=
INSURANCE_UPLOAD_API_KEY=

# Trucking new-carrier sub-inventory upload — for `daily_run --upload`.
# A separate Blob key holding only FMCSA new-carrier leads, so the
# outreach insurance-agency pack can pull the trucking list on its own.
# Best-effort: if unset, the run still writes the local trucking JSON and
# just skips the upload (the full insurance inventory is unaffected).
TRUCKING_UPLOAD_URL=
TRUCKING_UPLOAD_API_KEY=

# Commercial P&C sub-inventory upload — growth / trigger-moment leads
# (funding, new filings) that aren't new trucking carriers. Same best-effort
# behavior as the trucking key. Read by the P&C branch of the outreach pack.
PC_UPLOAD_URL=
PC_UPLOAD_API_KEY=

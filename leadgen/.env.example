# LLM providers (required for enrichment: domain / headcount / industry / insight)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Adzuna (optional second job-board feed; the run works without it)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Upload target. run.py posts each niche inventory to LEADS_UPLOAD_URL?niche=<key>
# with a Bearer LEADS_UPLOAD_API_KEY. Unset -> local JSON only, upload skipped.
LEADS_UPLOAD_URL=
LEADS_UPLOAD_API_KEY=

# Optional: pace the Gemini enrichment calls (seconds between calls).
GEMINI_MIN_INTERVAL_S=0.7

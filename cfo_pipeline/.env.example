# LLM providers (required for enrichment + outreach copy)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Apollo.io for decision-maker enrichment (required for the DM panel
# to populate; pipeline runs without it but the dashboard quality
# degrades significantly).
APOLLO_API_KEY=

# Adzuna (optional second job-board feed; pipeline works without it)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Upload to Vercel after generating leads.json
CFO_UPLOAD_URL=
CFO_UPLOAD_API_KEY=

# Bookkeeping sub-inventory upload (cfo_pipeline.bookkeeping_run --upload).
# A separate Blob key holding only junior finance hires (role_tier=junior),
# consumed by the outreach bookkeeping pack. Best-effort: if unset, the run
# still writes the local JSON and skips the upload. Independent of the CFO
# pipeline, which never touches these leads.
BOOKKEEPING_UPLOAD_URL=
BOOKKEEPING_UPLOAD_API_KEY=

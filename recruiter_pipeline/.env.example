# Copy to recruiter_pipeline/.env and fill in real values. Never commit .env.

# Upload the hiring-volume inventory (recruiter_pipeline.daily_run --upload).
# Its own Blob key, consumed by the outreach recruiter pack. Best-effort:
# if unset, the run still writes the local JSON and skips the upload.
RECRUITER_UPLOAD_URL=
RECRUITER_UPLOAD_API_KEY=
